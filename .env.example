# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key_here
VITE_SUPABASE_PROJECT_ID=your_supabase_project_ref_here

# Creator (admin) email — controls visibility of creator-only UI widgets
VITE_CREATOR_EMAIL=your_creator_email_here

# Demo account credentials — pre-filled on the sign-in form and used to gate
# demo read-only mode. Non-secret (RLS protects the data), but kept out of
# source so they can be changed per deployment.
VITE_DEMO_EMAIL=demo@example.com
VITE_DEMO_PASSWORD=change_me
